{
  "name": { "en": "WiFi Pool" },
  "id": "wifipool",
  "platforms": ["local","cloud"],
  "connectivity": ["lan", "cloud"],
  "class": "sensor",
  "images": {
    "xlarge": "/drivers/wifipool/assets/images/xlarge.jpg",
	"large": "/drivers/wifipool/assets/images/large.jpg",
    "small": "/drivers/wifipool/assets/images/small.jpg"
  }
  "capabilities": ["measure_ph", "measure_water_flow", "measure_redox"],
  "pair": [
    {
      "id": "view",
      "template": "view.html",
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices"
    }
  ],
  "settings": [
    {
      "id": "domain",
      "type": "text",
      "title": { "en": "Domain" }
    },
    {
      "id": "io",
      "type": "number",
      "title": { "en": "IO" }
    }
  ]
}
