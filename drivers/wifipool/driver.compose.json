      },
      "hint": {
        "en": "IP or hostname of the pool system"
      }
    }
  ],
  "images": {
    "xlarge": "/drivers/wifipool/assets/images/xlarge.jpg",
    "large": "/drivers/wifipool/assets/images/large.jpg",
    "small": "/drivers/wifipool/assets/images/small.jpg"
  }
}
