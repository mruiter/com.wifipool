{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.wifipool",
  "sdk": 3,
  "platforms": ["local","cloud"],
  "brandColor": "#0000FF",
  "name": {
    "en": "WiFi Pool"
  },
  "description": {
    "en": "Homey app for WiFi Pool sensors"
  },
  "category": [
    "appliances"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "version": "1.0.0",
  "compatibility": ">=12.2.0",
  "author": "WiFi Pool Team",
  "settings": [
    {
      "id": "email",
      "type": "text",
      "title": {
        "en": "Email"
      }
    },
    {
      "id": "password",
      "type": "password",
      "title": {
        "en": "Password"
      }
    }
  ],
  "drivers": [
    {
      "name": {
        "en": "WiFi Pool"
      },
	  "platforms": [
        "local"
      ],
      "connectivity": [
        "lan" , "cloud"
      ],
      "class": "sensor",
        "capabilities": [
          "measure_ph",
          "measure_water_flow",
          "measure_redox"
        ],
      "settings": [
        {
          "id": "domain",
          "type": "text",
          "label": {
            "en": "Domain"
          },
          "hint": {
            "en": "IP or hostname of the pool system"
          }
        },
        {
          "id": "io",
          "type": "number",
          "label": {
            "en": "IO Channel"
          },
          "hint": {
            "en": "The IO index for this sensor"
          }
        }
      ],
      "id": "wifipool",
	  "images": {
		"xlarge": "/drivers/wifipool/assets/images/xlarge.jpg",
		"large": "/drivers/wifipool/assets/images/large.jpg",
		"small": "/drivers/wifipool/assets/images/small.jpg"
		}
    }
  ],
  "capabilities": {
    "measure_ph": {
      "title": {
        "en": "pH"
      },
      "type": "number",
      "units": {
        "en": "pH"
      },
      "decimals": 2,
      "getable": true,
      "setable": false,
      "min": 0,
      "max": 14
    },
    "measure_water_flow": {
      "title": {
        "en": "Flow"
      },
      "type": "number",
      "units": {
        "en": "L/h"
      },
      "uiComponent": "sensor",
      "chartType": "line",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "min": 0
    },
    "measure_redox": {
      "title": {
        "en": "Redox",
        "nl": "Redox"
      },
      "type": "number",
      "uiComponent": "sensor",
      "units": {
        "en": "mV",
        "nl": "mV"
      },
      "icon": "/assets/redox.svg",
      "getable": true,
      "setable": false,
      "insightType": "number",
      "chartType": "line"
    }
  }
}
